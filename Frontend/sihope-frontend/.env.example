# Variables de entorno del frontend (Vite).
# Copia este archivo como .env (desarrollo) y define el valor adecuado.
# Toda variable expuesta al navegador DEBE comenzar con el prefijo VITE_.

# URL base del backend REST (sin barra final).
#   Desarrollo local:  http://localhost:8080
#   Producción/Vercel: https://<tu-backend-publico>
VITE_API_URL=http://localhost:8080
