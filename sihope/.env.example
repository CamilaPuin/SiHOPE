# Variables de entorno del backend SiHope.
# Copia este archivo como .env; docker-compose lo lee automáticamente.
# Todas tienen un valor por defecto en application.properties / docker-compose.yaml.

# --- Base de datos (conexión de la app a MySQL) ---
# Dentro de docker-compose usa el hostname del servicio: mysql:3306
# Fuera de Docker (app local contra el MySQL del compose): jdbc:mysql://localhost:13306/library
DB_URL=jdbc:mysql://mysql:3306/library
DB_USERNAME=user
DB_PASSWORD=library2026

# --- CORS ---
# Orígenes del frontend autorizados a consumir la API (separa varios por comas, sin espacios).
# Producción: incluye la URL de tu proyecto en Vercel, p. ej.:
#   APP_CORS_ALLOWED_ORIGINS=https://sihope.vercel.app
APP_CORS_ALLOWED_ORIGINS=http://localhost:5173
